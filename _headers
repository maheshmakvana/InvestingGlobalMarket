# ─────────────────────────────────────────────────────────────────────────────
# Cabeceras de seguridad HTTP — globalinvesting.github.io
# Compatible con: Cloudflare Pages, Netlify
# Última actualización: 2026-04-03
#
# FORMATO _headers (Netlify / Cloudflare Pages):
#   - Cada bloque empieza con una ruta en su propia línea (sin #)
#   - Las cabeceras van indentadas debajo, como "  Nombre: valor"
#   - Los comentarios solo pueden ser líneas que empiezan con #
#   - /* */ NO es sintaxis de comentario — es un path glob (coincide con todo)
# ─────────────────────────────────────────────────────────────────────────────

/*
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: SAMEORIGIN
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; script-src 'self' cdn.jsdelivr.net unpkg.com s3.tradingview.com widgets.tradingview-widget.com pagead2.googlesyndication.com partner.googleadservices.com tpc.googlesyndication.com https://www.googletagmanager.com https://www.google-analytics.com; style-src 'self' 'unsafe-inline' fonts.googleapis.com s3.tradingview.com widgets.tradingview-widget.com; font-src fonts.gstatic.com; img-src 'self' data: https: flagcdn.com; connect-src 'self' https://globalinvesting.github.io https://api.frankfurter.app https://api.worldbank.org https://api.stlouisfed.org https://api.exchangerate-api.com https://open.er-api.com https://sdmx.oecd.org https://api.coingecko.com https://freeserv.dukascopy.com https://www.myfxbook.com https://www.google-analytics.com https://analytics.google.com; frame-src googleads.g.doubleclick.net tpc.googlesyndication.com s3.tradingview.com widgets.tradingview-widget.com; frame-ancestors 'self'; upgrade-insecure-requests

# Datos JSON dinámicos — cache corto
/economic-data/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/cot-data/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=3600

/rates/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/ai-analysis/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=300

/extended-data/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/intraday-data/*
  Cache-Control: public, max-age=300, stale-while-revalidate=60

/news-data/*
  Cache-Control: public, max-age=1800, stale-while-revalidate=300

/sentiment-data/*
  Cache-Control: public, max-age=900, stale-while-revalidate=180

/meetings-data/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/fx-performance/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

/calendar-data/*
  Cache-Control: public, max-age=7200, stale-while-revalidate=600

